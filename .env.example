# FileParseEngine Configuration
# Copy this file to .env and fill in your API keys

# --- Parse Strategy ---
# fast    = Pure PyMuPDF extraction (FREE, default)
# ocr     = Local PaddleOCR PP-OCRv5 (FREE, handles scanned docs)
# hybrid  = PyMuPDF text + VLM for images (LOW cost)
# vlm     = Full VLM extraction for every page (HIGH cost)
FPE_STRATEGY=fast

# --- VLM Routes ---
# Custom YAML path; leave empty to auto-detect (./vlm_routes.yaml or package default)
# FPE_VLM_ROUTES_FILE=

# --- VLM Provider Keys (required for hybrid / vlm strategies) ---
FPE_OPENROUTER_API_KEY=sk-or-v1-xxxx
FPE_SILICONFLOW_API_KEY=sk-xxxx

# --- VLM Behavior ---
FPE_VLM_CONCURRENCY=5
FPE_VLM_TIMEOUT=60

# --- Image Processing ---
FPE_IMAGE_DPI=200
FPE_IMAGE_MAX_SIZE=4096
FPE_IMAGE_QUALITY=85

# --- Output ---
FPE_OUTPUT_DIR=output
